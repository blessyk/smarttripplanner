# Application Port
PORT=5001

# MongoDB Atlas Connection String
# Replace <username>, <password>, and <cluster> with your database details
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/smart_trip_planner?retryWrites=true&w=majority

# JWT Token Signing Secret Key (Must be a long, secure random string in production)
JWT_SECRET=your_jwt_signing_secret_key_here

# Runtime Node Environment ('development' or 'production')
NODE_ENV=development
